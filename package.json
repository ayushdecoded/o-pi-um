{
  "name": "o-pi-um",
  "version": "0.1.0",
  "private": true,
  "description": "A Pi extension package with goal loops, subagents, compaction routing, browser automation, web search, and a compact footer.",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "check": "npm run typecheck && npm run format:check",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/skill-commands/index.ts",
      "./extensions/goal/index.ts",
      "./extensions/subagent/index.ts",
      "./extensions/compaction/index.ts",
      "./extensions/footer/index.ts",
      "./extensions/browser/index.ts",
      "./extensions/web-search/index.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
