{
  "name": "o-pi-um",
  "version": "0.1.0",
  "private": true,
  "description": "A Pi package with goal loops, subagents, compaction routing, browser automation, web search, a compact footer, and hidden skills.",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "check": "npm run typecheck && npm run test && npm run format:check",
    "typecheck": "tsc --noEmit",
    "test": "node extensions/runner-core/test.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/goal/index.ts",
      "./extensions/robopi/index.ts",
      "./extensions/subagent/index.ts",
      "./extensions/compaction/index.ts",
      "./extensions/footer/index.ts",
      "./extensions/browser/index.ts",
      "./extensions/web-search/index.ts"
    ],
    "skills": [
      "./skills",
      "./extensions/robopi/skills"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "bin": {
    "robopi": "./bin/robopi.mjs"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-methods": "^6.0.0",
    "jiti": "^2.7.0",
    "yaml": "^2.9.0"
  }
}
